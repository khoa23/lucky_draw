@{
    Layout = null;
    ViewBag.Title = "Quản lý Lucky Draw";
}

<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TDbank - Dashboard</title>
    <link rel="icon" type="image/png" href="~/img/luckydrawicon.png">
    <!-- Local Assets -->
    <script src="~/lib/tailwind/tailwindcss.js"></script>
    <link rel="stylesheet" href="~/lib/animate.css/animate.min.css" />
    <link rel="stylesheet" href="~/lib/bootstrap-icons/bootstrap-icons.css" />
    <style>
        body {
            background: linear-gradient(135deg, #f3f4f6 0%, #e5e7eb 100%);
            min-height: 100vh;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        .card-menu {
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            border: 1px solid rgba(0, 0, 0, 0.05);
        }

        .card-menu:hover {
            transform: translateY(-10px);
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
            border-color: #c0262d;
        }

        .bg-agri {
            background-color: #c0262d;
        }

        .text-agri {
            color: #c0262d;
        }
    </style>
</head>

<body class="bg-gray-100">
    <nav class="bg-white shadow-md border-b-4 border-yellow-400">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-20">
                <div class="flex items-center">
                    <div class="flex-shrink-0 flex items-center gap-3">
                        <div class="p-1">
                            <img src="~/img/luckydrawicon.png" alt="Icon" class="h-12 w-12 object-contain">
                        </div>
                        <div>
                            <h1 class="text-2xl font-black text-agri tracking-tighter">LUCKY DRAW</h1>
                            <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest leading-none">
                                Management System</p>
                        </div>
                    </div>
                </div>
                <div class="flex items-center gap-4">
                    <div class="text-right hidden sm:block">
                        <p class="text-sm font-bold text-gray-800">Administrator</p>
                        <p class="text-xs text-gray-500">TDbank Local Session</p>
                    </div>
                    <div class="h-10 w-10 rounded-full bg-agri flex items-center justify-center text-white font-bold">
                        A
                    </div>
                </div>
            </div>
        </div>
    </nav>

    <main class="max-w-7xl mx-auto py-12 px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16 animate__animated animate__fadeInDown">
            <h2 class="text-4xl font-extrabold text-gray-900 sm:text-5xl sm:tracking-tight lg:text-6xl">
                Bảng điều khiển hệ thống
            </h2>
            <p class="mt-5 max-w-xl mx-auto text-xl text-gray-500 font-medium">
                Quản lý chương trình quay số, danh sách khách hàng và báo cáo kết quả trúng thưởng.
            </p>
        </div>

        <div class="grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-3 animate__animated animate__fadeInUp">
            <!-- Quay số -->
            <a href="~/LuckyDraw"
                class="card-menu bg-white overflow-hidden rounded-2xl shadow-sm p-8 flex flex-col items-center text-center group">
                <div
                    class="h-20 w-20 bg-red-50 rounded-2xl flex items-center justify-center mb-6 group-hover:bg-agri transition-colors">
                    <i class="bi bi-play-circle-fill text-agri text-4xl group-hover:text-white"></i>
                </div>
                <h3 class="text-2xl font-bold text-gray-900 mb-2">Quay số may mắn</h3>
                <p class="text-gray-500 text-sm">Trang giao diện chính hiển thị chương trình quay số cho khách hàng.</p>
            </a>

            <!-- Remote -->
            <a href="~/Remote"
                class="card-menu bg-white overflow-hidden rounded-2xl shadow-sm p-8 flex flex-col items-center text-center group">
                <div
                    class="h-20 w-20 bg-blue-50 rounded-2xl flex items-center justify-center mb-6 group-hover:bg-blue-600 transition-colors">
                    <i class="bi bi-phone-vibrate text-blue-600 text-4xl group-hover:text-white"></i>
                </div>
                <h3 class="text-2xl font-bold text-gray-900 mb-2">Điều khiển từ xa</h3>
                <p class="text-gray-500 text-sm">Sử dụng điện thoại di động để kích hoạt lệnh quay số từ xa qua mạng nội
                    bộ.</p>
            </a>

            <!-- Import -->
            <a href="~/Home/ImportExcel"
                class="card-menu bg-white overflow-hidden rounded-2xl shadow-sm p-8 flex flex-col items-center text-center group">
                <div
                    class="h-20 w-20 bg-green-50 rounded-2xl flex items-center justify-center mb-6 group-hover:bg-green-600 transition-colors">
                    <i class="bi bi-file-earmark-excel-fill text-green-600 text-4xl group-hover:text-white"></i>
                </div>
                <h3 class="text-2xl font-bold text-gray-900 mb-2">Import Dữ liệu</h3>
                <p class="text-gray-500 text-sm">Nạp danh sách khách hàng từ file Excel (Hỗ trợ dữ liệu lớn > 6 triệu
                    dòng).</p>
            </a>

            <!-- Report -->
            <a href="~/Report"
                class="card-menu bg-white overflow-hidden rounded-2xl shadow-sm p-8 flex flex-col items-center text-center group">
                <div
                    class="h-20 w-20 bg-purple-50 rounded-2xl flex items-center justify-center mb-6 group-hover:bg-purple-600 transition-colors">
                    <i class="bi bi-clipboard-data-fill text-purple-600 text-4xl group-hover:text-white"></i>
                </div>
                <h3 class="text-2xl font-bold text-gray-900 mb-2">Báo cáo kết quả</h3>
                <p class="text-gray-500 text-sm">Xem danh sách trúng thưởng, thống kê và xuất dữ liệu báo cáo.</p>
            </a>

            <!-- Settings -->
            <a href="~/Settings"
                class="card-menu bg-white overflow-hidden rounded-2xl shadow-sm p-8 flex flex-col items-center text-center group">
                <div
                    class="h-20 w-20 bg-yellow-50 rounded-2xl flex items-center justify-center mb-6 group-hover:bg-yellow-500 transition-colors">
                    <i class="bi bi-gear-fill text-yellow-600 text-4xl group-hover:text-white"></i>
                </div>
                <h3 class="text-2xl font-bold text-gray-900 mb-2">Cấu hình hệ thống</h3>
                <p class="text-gray-500 text-sm">Cài đặt chương trình, hạng mục giải thưởng và thông tin ngân hàng.</p>
            </a>

            <!-- Help -->
            <div
                class="card-menu bg-gray-50 overflow-hidden rounded-2xl shadow-sm p-8 flex flex-col items-center text-center opacity-60">
                <div class="h-20 w-20 bg-gray-200 rounded-2xl flex items-center justify-center mb-6">
                    <i class="bi bi-question-circle-fill text-gray-500 text-4xl"></i>
                </div>
                <h3 class="text-2xl font-bold text-gray-900 mb-2">Hướng dẫn</h3>
                <p class="text-gray-500 text-sm">Tài liệu hướng dẫn sử dụng hệ thống quay số may mắn TDbank.</p>
            </div>
        </div>
    </main>

    <footer class="max-w-7xl mx-auto py-12 px-4 border-t border-gray-200 text-center">
        <p class="text-gray-400 text-sm font-medium">&copy; 2026 TDbank Management System. Optimize for Big Data.</p>
    </footer>
</body>

</html>
